# ─── Discord ────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CHANNEL_DAILY=123456789          # Channel ID for daily briefs
DISCORD_CHANNEL_TRAINING=123456789       # Channel ID for training log / chat
OWNER_USER_ID=123456789                  # Your Discord user ID (right-click your name → Copy ID)

# ─── Strava ──────────────────────────────────────────────────────────────────
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REFRESH_TOKEN=your_strava_refresh_token

# ─── WHOOP ───────────────────────────────────────────────────────────────────
WHOOP_CLIENT_ID=your_whoop_client_id
WHOOP_CLIENT_SECRET=your_whoop_client_secret
WHOOP_REFRESH_TOKEN=your_whoop_refresh_token

# ─── Anthropic (Claude) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key
CLAUDE_MODEL=claude-sonnet-4-6

# ─── Notion ───────────────────────────────────────────────────────────────────
NOTION_API_KEY=your_notion_integration_token
NOTION_DATABASE_ID=your_notion_database_id

# ─── Bot Settings ─────────────────────────────────────────────────────────────
# The morning brief fires when today's WHOOP recovery record arrives, anywhere
# within the poll window. Before START, no check. After BACKSTOP, fire anyway.
DAILY_BRIEF_POLL_START=05:30   # earliest possible brief (24h, local time)
DAILY_BRIEF_BACKSTOP=10:00     # fire even if WHOOP hasn't synced by this time
DAILY_BRIEF_TIME=07:30         # legacy — kept for display only, not the trigger
TIMEZONE=America/New_York
DB_PATH=data/fitness_bot.db

# ─── Home location (weather + AQI) ───────────────────────────────────────────
# Coordinates for the Open-Meteo forecast. Set to your home lat/lng; you can
# grab them from Google Maps (right-click → copy coordinates).
HOME_LAT=0.0
HOME_LNG=0.0
HOME_CITY="Your City, ST 00000"

# ─── Webhook server (Strava + WHOOP push, replaces nightly polling) ──────────
# Leave WEBHOOK_PORT=0 (or unset) to disable webhooks and keep the old
# polling-only behavior. Set to any free port (8765 is a safe default) and
# put Caddy in front terminating TLS. See docs/webhooks.md for the full
# DigitalOcean + Caddy walkthrough.
WEBHOOK_HOST=127.0.0.1
WEBHOOK_PORT=0
# Public HTTPS base URL Caddy exposes for the bot. Example:
# WEBHOOK_PUBLIC_URL=https://coachrex.example.com
# (The scripts/strava_subscribe.py helper will POST callback_url=<this>/webhooks/strava
# to Strava.)
WEBHOOK_PUBLIC_URL=
# Random secret that Strava will echo back in the hub.verify_token query
# param during the initial GET handshake. Generate once with e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
STRAVA_WEBHOOK_VERIFY_TOKEN=
