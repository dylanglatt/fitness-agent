# ─── Discord ─────────────────────────────────────────────────────────────────
# Create a bot at https://discord.com/developers/applications, copy the token,
# enable "Message Content Intent" under Privileged Gateway Intents, and invite
# the bot to your server with: Send Messages, Read Message History, Use
# Application Commands. The owner user ID comes from right-clicking your name
# → Copy ID (enable Developer Mode in Discord settings first). Scheduled briefs,
# weekly summaries, and Stoic reflections are DM'd directly to the owner — no
# channel IDs needed.
DISCORD_TOKEN=your_discord_bot_token
OWNER_USER_ID=123456789                  # Your Discord user ID
# Optional: if set, slash commands sync to this single guild (instant).
# If 0/unset, sync is global and can take up to an hour to propagate.
DISCORD_GUILD_ID=0

# ─── Strava ──────────────────────────────────────────────────────────────────
# Create an app at https://www.strava.com/settings/api. Then run the one-time
# OAuth flow described in docs/strava_auth.md to get your refresh token.
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REFRESH_TOKEN=your_strava_refresh_token

# ─── WHOOP ───────────────────────────────────────────────────────────────────
# Create an app at https://developer.whoop.com. Then run the OAuth flow in
# docs/whoop_auth.md to get your refresh token.
WHOOP_CLIENT_ID=your_whoop_client_id
WHOOP_CLIENT_SECRET=your_whoop_client_secret
WHOOP_REFRESH_TOKEN=your_whoop_refresh_token

# ─── Anthropic (Claude) ──────────────────────────────────────────────────────
# Get an API key at https://console.anthropic.com.
#
# Two-model split (cost lever — see ai/coach.py):
#   CLAUDE_MODEL  — used for the morning brief, weekly summary, Sunday
#                   reflection, and post-workout debriefs. Quality of prose
#                   matters here.
#   CHAT_MODEL    — used for the conversational chat path. Most chats are
#                   short and Haiku does them ~3× cheaper.
# Set COACH_CHEAP_MODE=0 to force CLAUDE_MODEL on the chat path too.
ANTHROPIC_API_KEY=your_anthropic_api_key
CLAUDE_MODEL=claude-sonnet-4-6
CHAT_MODEL=claude-haiku-4-5-20251001
COACH_CHEAP_MODE=1

# ─── Notion ──────────────────────────────────────────────────────────────────
# Four databases under a "Fitness" parent page:
#   SCHEDULE    — day-level index (Training Group + Workout per date)
#   LIFTS       — one row per exercise per day (Sets, Reps, Weight lb, RPE)
#   RUNS        — one row per cardio activity (Distance mi, Pace, HR zone %)
#   DAILY LOG   — WHOOP recovery/HRV/RHR + sleep + morning brief text
# Schedule rows relate to Lifts/Runs/Daily Log via Notion Relations so a
# single day view shows the whole session.
#
# API key: https://www.notion.so/profile/integrations → + New integration
#          (Internal) → copy the "Internal Integration Secret".
# Database IDs: open each database as a full page → copy URL → the 32-char
#               chunk before the "?" is the ID.
# IMPORTANT: open each database → ••• → Connections → add your integration.
#            Without that step the API returns 404 even with a valid key.
#
# Any ID can be left blank/"your_..." — the bot skips writes to that DB
# rather than crashing. This lets you roll out one DB at a time.
NOTION_API_KEY=your_notion_integration_token
NOTION_SCHEDULE_DATABASE_ID=your_notion_schedule_database_id
NOTION_LIFTS_DATABASE_ID=your_notion_lifts_database_id
# Per-set granular log (one row per SET, linked back to the parent Lifts
# row via the "Parent Lift" relation). Leave blank to skip Lift Sets writes
# — the bot still writes workout-summary rows to NOTION_LIFTS_DATABASE_ID.
NOTION_LIFT_SETS_DATABASE_ID=your_notion_lift_sets_database_id
NOTION_RUNS_DATABASE_ID=your_notion_runs_database_id
NOTION_DAILY_DATABASE_ID=your_notion_daily_database_id

# ─── Bot Settings ────────────────────────────────────────────────────────────
# The morning brief fires when today's WHOOP recovery record arrives, anywhere
# within the poll window. Before START, no check. After BACKSTOP, fire anyway.
DAILY_BRIEF_POLL_START=05:30   # earliest possible brief (24h, local time)
DAILY_BRIEF_BACKSTOP=10:00     # fire even if WHOOP hasn't synced by this time
TIMEZONE=America/New_York
DB_PATH=data/fitness_agent.db

# ─── Home location (weather + AQI) ───────────────────────────────────────────
# Coordinates for the Open-Meteo forecast. Grab from Google Maps (right-click
# → copy coordinates). Leave HOME_LAT and HOME_LNG at 0.0, or HOME_CITY blank,
# to skip weather entirely — the rest of the bot still works.
HOME_LAT=0.0
HOME_LNG=0.0
HOME_CITY=

# ─── Webhook server (Strava + WHOOP push, replaces nightly polling) ──────────
# Leave WEBHOOK_PORT=0 (or unset) to disable webhooks and keep polling-only
# behavior. Set to any free port (8765 is a safe default) and put Caddy in
# front terminating TLS. See docs/webhooks.md for the full deploy walkthrough.
WEBHOOK_HOST=127.0.0.1
WEBHOOK_PORT=0
# Public HTTPS base URL Caddy exposes for the bot. Example:
# WEBHOOK_PUBLIC_URL=https://fitness-agent.example.com
# (scripts/strava_subscribe.py POSTs callback_url=<this>/webhooks/strava to Strava.)
WEBHOOK_PUBLIC_URL=
# Random secret that Strava will echo back in the hub.verify_token query
# param during the initial GET handshake. Generate once with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
STRAVA_WEBHOOK_VERIFY_TOKEN=
